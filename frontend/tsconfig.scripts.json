{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": ".scripts-out",
    "noEmit": false,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["scripts/**/*.ts", "lib/dev/**/*.ts", "lib/core/logger.ts"],
  "exclude": ["node_modules", ".next"]
}
