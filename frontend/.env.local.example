# ─────────────────────────────────────────────
# Clerk Authentication
# Get from https://dashboard.clerk.com → API Keys
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret
# Get from https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
# Register endpoint: https://yourdomain.com/api/webhooks/clerk
# Events: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# ─────────────────────────────────────────────
# Database (Neon PostgreSQL recommended)
# Get from https://neon.tech → Connection string
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/buildforge?sslmode=require
DIRECT_URL=postgresql://user:password@host/buildforge?sslmode=require

# ─────────────────────────────────────────────
# AI Keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# ─────────────────────────────────────────────
# Stripe Payments
# Get from https://dashboard.stripe.com → API Keys
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret
# Get from https://dashboard.stripe.com → Webhooks → your endpoint
# Register endpoint: https://yourdomain.com/api/webhooks/stripe
# Events: customer.subscription.created, customer.subscription.updated,
#         customer.subscription.deleted, invoice.paid
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs — create products in Stripe dashboard first
# Plans: Pro ($19/mo), Team ($49/mo), Enterprise (custom)
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_your_pro_yearly_id
STRIPE_PRICE_TEAM_MONTHLY=price_your_team_monthly_id
STRIPE_PRICE_TEAM_YEARLY=price_your_team_yearly_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_your_enterprise_monthly_id
STRIPE_PRICE_ENTERPRISE_YEARLY=price_your_enterprise_yearly_id

# ─────────────────────────────────────────────
# Deployment Integrations
# ─────────────────────────────────────────────
VERCEL_TOKEN=your_vercel_token
NETLIFY_TOKEN=your_netlify_token

# GitHub (server-side fallback — users can also add their own token in Settings)
GITHUB_TOKEN=your_github_personal_access_token

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin user IDs (comma-separated Clerk user IDs)
# These users bypass credit checks and get admin panel access
# Example: ADMIN_USER_IDS=user_abc123,user_def456
ADMIN_USER_IDS=

# Cron secret for /api/credits/reset endpoint
CRON_SECRET=your_cron_secret_here

# ─────────────────────────────────────────────
# Local AI (optional — for Local AI Mode)
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model
TABBY_BASE_URL=http://localhost:8080
TABBY_API_KEY=
CODEIUM_API_KEY=

# AI Provider selection: auto | ollama | gemini | openai
# auto = tries ollama first, falls back to cloud
# ollama = local only (requires Ollama running)
# gemini = Google Gemini API only
# openai = OpenAI API only
AI_PROVIDER=auto
